<ActionDefinition xmlns:gr="http://www.webratio.com/2006/WebML/Graph" id="mpkg3#ada4" name="Attiva utenza" defaultSuccessPortDefinition="mpkg3#ada4#spd6" defaultErrorPortDefinition="mpkg3#ada4#epd6" transaction="true">
  <InputPortDefinition id="mpkg3#ada4#ipd6" gr:x="0" gr:y="30">
