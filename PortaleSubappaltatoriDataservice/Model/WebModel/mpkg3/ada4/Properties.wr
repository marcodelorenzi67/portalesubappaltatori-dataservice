    <Switch gr:x="500" gr:y="260" id="mpkg3#ada4#switch2" name="attivo">
      <Case value="true"/>
      <SuccessFlow id="mpkg3#ada4#switch2#sf47" to="mpkg3#ada4#epd6" automaticCoupling="true"/>
      <SuccessFlow id="mpkg3#ada4#switch2#sf48" to="mpkg3#ada4#seu7" automaticCoupling="true" code="true"/>
    </Switch>
    <Selector gr:x="500" gr:y="380" id="mpkg3#ada4#seu7" dataBinding="cls6" name="Check tipo token">
