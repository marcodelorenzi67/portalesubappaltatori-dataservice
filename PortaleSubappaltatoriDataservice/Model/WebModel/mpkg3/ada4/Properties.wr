      <DataFlow id="mpkg3#ada4#seu6#df20" to="mpkg3#ada4#act8">
        <ParameterBinding id="mpkg3#ada4#seu6#df20#par75" source="cls4#att19Array" target="mpkg3#ada4#act8.mpkg3#ada5#ipd7#pdp21" name="Cognome - Cognome"/>
        <ParameterBinding id="mpkg3#ada4#seu6#df20#par76" source="cls4#att20Array" target="mpkg3#ada4#act8.mpkg3#ada5#ipd7#pdp22" name="Email - Email"/>
        <ParameterBinding id="mpkg3#ada4#seu6#df20#par77" source="cls4#att18Array" target="mpkg3#ada4#act8.mpkg3#ada5#ipd7#pdp23" name="Nome - Nome"/>
      </DataFlow>
      <DataFlow id="mpkg3#ada4#seu6#df39" to="mpkg3#ada4#act9">
        <ParameterBinding id="mpkg3#ada4#seu6#df39#par140" sourceValue="${token.invito}" target="mpkg3#ada4#act9.mpkg3#ada6#ipd8#pdp27" name="&quot;${token.invito}&quot; - Tipo token"/>
        <ParameterBinding id="mpkg3#ada4#seu6#df39#par141" source="cls4#att20Array" target="mpkg3#ada4#act9.mpkg3#ada6#ipd8#pdp26" name="Email - user invitato [Email]"/>
      </DataFlow>
      <DataFlow id="mpkg3#ada4#seu6#df67o" to="mpkg3#ada4#act27o">
        <ParameterBinding id="mpkg3#ada4#seu6#df67o#par242o" source="as4#role7_cls2#att6Array" target="mpkg3#ada4#act27o.tlads0#ada17o#ipd25o#pdp70o" name="Pre RegistrazioneToFornitore.oid - oid Fornitore"/>
