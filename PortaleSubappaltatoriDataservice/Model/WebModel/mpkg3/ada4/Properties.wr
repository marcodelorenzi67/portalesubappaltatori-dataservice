  <SuccessPortDefinition id="mpkg3#ada4#spd6" name="Success Port" gr:x="0" gr:y="605"/>
  <ErrorPortDefinition id="mpkg3#ada4#epd6" name="Error Port" gr:x="0" gr:y="125"/>
  <Operations>
    <Selector gr:x="370" gr:y="85" id="mpkg3#ada4#seu6" dataBinding="cls4">
      <SuccessFlow id="mpkg3#ada4#seu6#sf45" to="mpkg3#ada4#switch2">
        <ParameterBinding id="mpkg3#ada4#seu6#sf45#par40" source="cls4#att58Array" target="mpkg3#ada4#switch2.switch" name="is token valido - Switch"/>
      </SuccessFlow>
      <ConditionalExpression id="mpkg3#ada4#seu6#sc10" defaultPolicy="fill" booleanOperator="and">
        <AttributesCondition id="mpkg3#ada4#seu6#sc10#acond6" name="token" predicate="eq" booleanOperator="or" implied="false" attributes="cls4#att56"/>
      </ConditionalExpression>
      <SuccessFlow id="mpkg3#ada4#seu6#sf46" to="mpkg3#ada4#epd6" automaticCoupling="true" code="Not Found"/>
      <DataFlow id="mpkg3#ada4#seu6#df11" to="mpkg3#ada4#seu7">
        <ParameterBinding id="mpkg3#ada4#seu6#df11#par41" source="cls4#att56Array" target="mpkg3#ada4#seu7#sc11#kcond5.cls6#att27" name="User invitatiToToken.Descrizione - KeyCondition5 [Descrizione]"/>
