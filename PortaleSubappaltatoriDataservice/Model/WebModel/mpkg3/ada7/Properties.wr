<ActionDefinition xmlns:gr="http://www.webratio.com/2006/WebML/Graph" id="mpkg3#ada7" name="Password dimenticata" defaultSuccessPortDefinition="mpkg3#ada7#spd10" defaultErrorPortDefinition="mpkg3#ada7#epd10">
  <InputPortDefinition id="mpkg3#ada7#ipd10" gr:x="0" gr:y="30">
    <SuccessFlow id="mpkg3#ada7#ipd10#sf96" to="mpkg3#ada7#scu2">
      <ParameterBinding id="mpkg3#ada7#ipd10#sf96#par98" source="mpkg3#ada7#ipd10#pdp30" target="mpkg3#ada7#scu2.originalValue" name="originalValue - originalValue"/>
    </SuccessFlow>
    <PortDefinitionParameter id="mpkg3#ada7#ipd10#pdp30" array="false" name="email" type="string"/>
