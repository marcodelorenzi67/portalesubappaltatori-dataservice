  <SuccessPortDefinition id="mpkg3#ada7#spd10" name="Success Port" gr:x="0" gr:y="145"/>
  <ErrorPortDefinition id="mpkg3#ada7#epd10" name="Error Port" gr:x="0" gr:y="55"/>
  <Operations>
    <Script id="mpkg3#ada7#scu2" name="Sanitize mail" gr:x="0" gr:y="0" script="WEB-INF/groovy/trimAndToLowerCaseString.groovy">
      <SuccessFlow id="mpkg3#ada7#scu2#sf95" to="mpkg3#ada7#seu15">
        <ParameterBinding id="mpkg3#ada7#scu2#sf95#par97" name="result - userId" source="result(result)" target="mpkg3#ada7#seu15#sc30#acond11"/>
      </SuccessFlow>
    </Script>
    <Selector id="mpkg3#ada7#seu15" gr:x="180" gr:y="35" dataBinding="User">
      <ConditionalExpression id="mpkg3#ada7#seu15#sc30" defaultPolicy="fill" booleanOperator="and">
        <AttributesCondition id="mpkg3#ada7#seu15#sc30#acond11" name="userId" predicate="eq" booleanOperator="or" implied="false" attributes="userName"/>
      </ConditionalExpression>
      <SuccessFlow id="mpkg3#ada7#seu15#sf97" to="mpkg3#ada7#spd10" automaticCoupling="true" code="Not Found"/>
      <SuccessFlow id="mpkg3#ada7#seu15#sf100" to="mpkg3#ada7#tmu2" automaticCoupling="true"/>
      <DataFlow id="mpkg3#ada7#seu15#df32" to="mpkg3#ada7#svu4" automaticCoupling="true"/>
      <DataFlow id="mpkg3#ada7#seu15#df35" to="mpkg3#ada7#act14">
        <ParameterBinding id="mpkg3#ada7#seu15#df35#par118" source="User#att4Array" target="mpkg3#ada7#act14.mpkg2#ada3#ipd4#pdp12" name="Cognome - Cognome"/>
        <ParameterBinding id="mpkg3#ada7#seu15#df35#par119" source="User#att5Array" target="mpkg3#ada7#act14.mpkg2#ada3#ipd4#pdp10" name="Email - Email"/>
        <ParameterBinding id="mpkg3#ada7#seu15#df35#par120" source="User#att3Array" target="mpkg3#ada7#act14.mpkg2#ada3#ipd4#pdp11" name="Nome - Nome"/>
      </DataFlow>
    </Selector>
    <Save id="mpkg3#ada7#svu4" gr:x="500" gr:y="380" action="create" dataBinding="cls6">
      <SuccessFlow id="mpkg3#ada7#svu4#sf113" to="mpkg3#ada7#act13">
        <ParameterBinding id="mpkg3#ada7#svu4#sf113#par114" source="cls6#att27Array" target="mpkg3#ada7#act13.mpkg2#adf5#ipd12#pdp35" name="Descrizione - token"/>
      </SuccessFlow>
    </Save>
    <Time id="mpkg3#ada7#tmu2" name="Time" gr:x="295" gr:y="200">
      <SuccessFlow id="mpkg3#ada7#tmu2#sf98" to="mpkg3#ada7#act10">
        <ParameterBinding id="mpkg3#ada7#tmu2#sf98#par99" name="&quot;${token.invito}&quot; - codice" sourceValue="${token.psw}" target="mpkg3#ada7#act10.mpkg2#ada2#ipd2#pdp1"/>
